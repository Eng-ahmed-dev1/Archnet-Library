<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>archnet</ToolCommandName>

    <PackageId>Archnet</PackageId>
    <IsPackable>true</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Archnet.Core\Archnet.Core.csproj" />
    <ProjectReference Include="..\Archnet.Generators\Archnet.Generators.csproj" />
  </ItemGroup>

</Project>